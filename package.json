{
  "name": "the-masterbook",
  "version": "0.1.0-alpha",
  "description": "The Masterbook — Production Management Desktop App",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "vite & electron . --dev",
    "build:svelte": "vite build",
    "start": "electron .",
    "build": "npm run build:svelte && electron-builder --mac",
    "build:dmg": "npm run build:svelte && electron-builder --mac dmg",
    "build:zip": "npm run build:svelte && electron-builder --mac zip"
  },
  "author": "Kyle Henke",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "svelte": "^5.55.2",
    "vite": "^8.0.7"
  },
  "build": {
    "appId": "com.masterbook.app",
    "productName": "The Masterbook",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "dist-svelte/**/*",
      "assets/**/*",
      "public/**/*",
      "vendor/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "The Masterbook",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "pdf-lib": "^1.17.1"
  }
}
